{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxide",
  "version": "0.1.0",
  "identifier": "dev.pmdcoutinho.voxide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Voxide",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "Voxide Dictation",
        "width": 520,
        "height": 132,
        "center": true,
        "visible": false,
        "focus": false,
        "focusable": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/Voxide/audio-history/**", "$LOCALDATA/voxide/audio-history/**"]
      },
      "csp": "default-src 'self'; connect-src 'self' https: http:; img-src 'self' asset: http: https: data:; media-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "linux": {
      "deb": {
        "depends": ["libasound2", "libxkbcommon0"]
      },
      "rpm": {
        "depends": ["alsa-lib", "libxkbcommon"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
